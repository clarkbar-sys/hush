# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
*.code-workspace

# ── Logs & temp ───────────────────────────────────────────────
*.log
tmp/
.cache/

# ── Staged web preview (scripts/build-web-preview.sh output) ──
/_preview/

# ── Secrets & local env (never commit these) ─────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Go ────────────────────────────────────────────────────────
/bin/
/hush-agent
/hush-control
*.test
*.out

# ── Local fleet config (contains your tailnet addresses) ──────
/fleet.json

# ── Language-specific: uncomment the section for other stacks ─
#
# Python:
# __pycache__/
# *.py[cod]
# .venv/
# .pytest_cache/
# .ruff_cache/
