[Unit]
Description=hush-control — periodic self-update check
Documentation=https://github.com/clarkbar-sys/hush

[Timer]
# Check about a day after boot, then daily. RandomizedDelaySec spreads the
# GitHub call out so a fleet of boxes doesn't all hit the API at the same
# instant, and Persistent catches up a check missed while the box was off.
OnBootSec=1h
OnUnitActiveSec=24h
RandomizedDelaySec=1h
Persistent=true

[Install]
WantedBy=timers.target
