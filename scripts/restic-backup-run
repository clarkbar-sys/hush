#!/usr/bin/env sh
# Runs one convention-named restic backup and records its outcome where an
# unprivileged hush-agent can read it.
#
#   restic-backup-run <name>
#
# Reads three files, all named after the backup:
#
#   /etc/restic/<name>.env        credentials (0600, root-only)
#   /etc/restic/<name>.paths      what to back up, one path per line
#   /etc/restic/<name>.excludes   what to skip (optional)
#
# and writes one:
#
#   /var/lib/hush-backups/<name>.json   last-run status, world-readable
#
# That split is the whole point. The backup itself needs root — it reads
# /home, service state dirs, and anything else an unprivileged user can't —
# but hush-agent runs as an unprivileged user and must never hold a repo
# credential. So the privileged side writes a status file containing no
# secrets, and the agent only ever reads that. The repository URL is recorded
# with its userinfo stripped, since restic's `rest:` backend carries HTTP auth
# inline in the URL.
#
# Exit code is restic's own, unchanged. In particular restic exits 3 when some
# source data could not be read: a snapshot exists but is INCOMPLETE. It is
# reported as a failure here on purpose — an incomplete backup that looks green
# is worse than one that looks broken.

set -eu

NAME="${1:-}"
if [ -z "$NAME" ]; then
  echo "usage: restic-backup-run <name>" >&2
  exit 2
fi

CONF_DIR="${RESTIC_CONF_DIR:-/etc/restic}"
STATUS_DIR="${HUSH_BACKUP_STATUS_DIR:-/var/lib/hush-backups}"

# Runs kept in <name>.history.jsonl. The console draws 14; the surplus is
# headroom so a couple of manual runs don't push a fortnight off the strip.
HISTORY_KEEP="${HUSH_BACKUP_HISTORY_KEEP:-30}"

ENV_FILE="$CONF_DIR/$NAME.env"
PATHS_FILE="$CONF_DIR/$NAME.paths"
EXCLUDES_FILE="$CONF_DIR/$NAME.excludes"

# systemd's EnvironmentFile= has usually already loaded these; sourcing here
# too keeps the script runnable by hand for a one-off or a restore drill.
if [ -z "${RESTIC_REPOSITORY:-}" ]; then
  if [ ! -r "$ENV_FILE" ]; then
    echo "error: $ENV_FILE not readable and RESTIC_REPOSITORY unset" >&2
    exit 2
  fi
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

if [ ! -r "$PATHS_FILE" ]; then
  echo "error: $PATHS_FILE not readable — nothing to back up" >&2
  exit 2
fi

# Strip userinfo from a repository URL. restic's rest: backend takes HTTP auth
# only via the URL, so the raw value is a credential and must never reach the
# world-readable status file. Two forms, because restic uses both:
#   rest:http://user:pass@host/path  ->  rest:http://host/path
#   sftp:user@host:/path             ->  sftp:host:/path
# The sftp form carries no password (it authenticates by key), but a username
# still doesn't belong in a file everyone on the box can read.
redact_repo() {
  printf '%s' "$1" \
    | sed -e 's#://[^@/]*@#://#' \
          -e 's#^\([a-z0-9]*:\)[^@/:]*@#\1#'
}

mkdir -p "$STATUS_DIR"
chmod 0755 "$STATUS_DIR"

# paths_json renders the .paths file as a JSON array so the console can show
# what a backup actually covers. Only two characters can break a JSON string in
# a path — backslash and double quote — so only those are escaped. Comments and
# blank lines are dropped, matching what --files-from itself ignores.
#
# These land in a world-readable file. They are not secrets, but they do
# describe the box's layout to any local user; a box that considers its
# directory names sensitive should tighten HUSH_BACKUP_STATUS_DIR.
#
# Defined before the run because the start-of-run status file below wants the
# covered paths too, not just the final one.
paths_json() {
  _first=1
  printf '['
  while IFS= read -r _line || [ -n "$_line" ]; do
    case "$_line" in '' | '#'*) continue ;; esac
    _esc="$(printf '%s' "$_line" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    if [ "$_first" -eq 1 ]; then _first=0; else printf ','; fi
    printf '"%s"' "$_esc"
  done <"$1"
  printf ']'
}

# json_num pulls one numeric field out of a JSON object without a parser. Safe
# only for fields whose values are bare numbers — which is every field the
# progress file carries, and is precisely why it carries only those.
json_num() {
  printf '%s' "$1" | grep -o "\"$2\":[0-9.eE+-]*" | head -n 1 | cut -d: -f2-
}

started="$(date -Is)"

# Announce the run before restic starts. Until now the status dir stayed empty
# for the entire run, and an empty dir already carries a meaning — "no backup
# configured, this box is unprotected". So a first backup grinding through a
# terabyte was on the map as indistinguishable from a box nobody ever set up.
# A start-of-run file with "state":"running" makes "working on it" its own,
# legible thing; the end-of-run mv below overwrites it with the real outcome.
#
# Written the same atomic way as the final status (temp then mv) so a reader
# never catches a half-written file, and carrying none of exit_code/ok/finished
# — a run in flight has no outcome yet, and leaving those out is what keeps an
# older console (which never learned about "state") from reading a running
# backup as a completed one.
running_status="$(mktemp)"
cat >"$running_status" <<EOF
{
  "name": "$NAME",
  "repository": "$(redact_repo "${RESTIC_REPOSITORY:-}")",
  "paths": $(paths_json "$PATHS_FILE"),
  "started": "$started",
  "state": "running"
}
EOF
chmod 0644 "$running_status"
mv "$running_status" "$STATUS_DIR/$NAME.json"

output="$(mktemp)"

# Live progress, published beside the status file.
#
# restic --json emits one status object per line to stdout the whole time it
# works, carrying percent_done, bytes_done/total_bytes and an ETA. This script
# was already capturing that stream — for the final summary line — and throwing
# the rest away, so the console could only ever draw an indeterminate shuttle
# for a run in flight. A poller copies the newest status line's numbers into a
# world-readable file, which costs the agent no new privilege: the same one-way
# split the rest of this script exists to maintain.
#
# Numbers only, reassembled by hand rather than passed through verbatim, for
# two reasons. restic's status line also carries current_files — the absolute
# paths being read *right now*, far more revealing than the top-level path list
# already published, and this file is 0644. And an object of bare numbers needs
# no string escaping, which is the same reason the summary is embedded whole
# instead of being rebuilt.
progress_file="$STATUS_DIR/$NAME.progress.json"

# A run killed outright (SIGKILL, OOM, power) never runs the cleanup below and
# leaves its progress behind. Clear it up front so a fresh run cannot briefly
# show the previous one's percentage.
rm -f "$progress_file"

publish_progress() {
  _line="$(grep '"message_type":"status"' "$output" 2>/dev/null | tail -n 1)" || return 0
  [ -n "$_line" ] || return 0

  # percent_done is the one field the console cannot render without. Every
  # other field is optional: restic omits seconds_remaining until it has an
  # estimate, and files_done until the first file lands.
  _pct="$(json_num "$_line" percent_done)"
  [ -n "$_pct" ] || return 0

  _fields="\"percent_done\":$_pct"
  for _k in bytes_done total_bytes files_done total_files seconds_remaining; do
    _v="$(json_num "$_line" "$_k")"
    if [ -n "$_v" ]; then
      _fields="$_fields,\"$_k\":$_v"
    fi
  done

  # The temp file is made in STATUS_DIR, not $TMPDIR, so the mv is a rename
  # within one filesystem and therefore atomic. A reader polling this file
  # several times a minute would otherwise eventually catch a cross-device mv
  # mid-copy and see a truncated object.
  _tmp="$(mktemp "$STATUS_DIR/.$NAME.progress.XXXXXX")"
  printf '{"name":"%s","updated":"%s",%s}\n' "$NAME" "$(date -Is)" "$_fields" >"$_tmp"
  chmod 0644 "$_tmp"
  mv "$_tmp" "$progress_file"
}

# A function, not an inline trap, so the last thing cleanup runs is always a
# succeeding rm. A trap ending in a failing command can carry that status out
# as the script's own, and this script's exit code is restic's verdict — the
# difference between a green backup and an incomplete one.
cleanup() {
  rm -f "$output"
  if [ -n "${progress_pid:-}" ]; then
    kill "$progress_pid" 2>/dev/null || true
  fi
  # Removed on the way out: once the run is over the status file carries the
  # real outcome, and a leftover percentage is a number with nothing behind it.
  rm -f "$progress_file"
}
trap cleanup EXIT INT TERM

# Seconds between progress publishes. Set to 0 to switch live progress off; the
# console then falls back to the indeterminate shuttle it drew before this
# existed, which is the same thing it shows for a runner too old to publish.
progress_interval="${HUSH_BACKUP_PROGRESS_INTERVAL:-5}"
progress_pid=""
if [ "$progress_interval" -gt 0 ] 2>/dev/null; then
  (
    # Drop the inherited traps before doing anything else. dash, bash and
    # busybox ash all reset them for an async subshell already, but this script
    # runs under whatever /bin/sh a box happens to have, and the failure mode if
    # one does not is severe and silent: the poller would run cleanup on its own
    # way out, deleting $output while restic is still writing to it, and the run
    # would finish with its summary gone and no sign of why.
    trap - EXIT INT TERM
    while :; do
      sleep "$progress_interval"
      publish_progress || true
    done
  ) &
  progress_pid=$!
fi

set -- backup --json --files-from "$PATHS_FILE" --tag hush
if [ -r "$EXCLUDES_FILE" ]; then
  set -- "$@" --exclude-file "$EXCLUDES_FILE"
fi

# restic's own exit code is what we report, so don't let set -e swallow it.
rc=0
restic "$@" >"$output" 2>&1 || rc=$?
cat "$output"

# restic --json emits one object per line; the final summary carries the
# counts and the new snapshot id. Embed it verbatim rather than reparsing —
# no jq/python dependency, and no chance of mangling it in shell.
summary="$(grep '"message_type":"summary"' "$output" | tail -n 1 || true)"
[ -n "$summary" ] || summary=null

if [ "$rc" -eq 0 ]; then ok=true; else ok=false; fi
if [ "$rc" -eq 3 ]; then incomplete=true; else incomplete=false; fi
finished="$(date -Is)"

# The final status carries no "state" field: a finished run has an outcome
# (ok/incomplete/exit_code), not a state, and omitting it both restores today's
# schema exactly and clears the "running" marker written at the top when this
# file overwrites it.
#
# Deliberately does NOT embed restic's stderr: escaping arbitrary text into
# JSON from shell is a good way to emit invalid JSON. Diagnostics live in the
# journal, which is where you want them anyway.
tmp_status="$(mktemp)"
cat >"$tmp_status" <<EOF
{
  "name": "$NAME",
  "repository": "$(redact_repo "${RESTIC_REPOSITORY:-}")",
  "paths": $(paths_json "$PATHS_FILE"),
  "started": "$started",
  "finished": "$finished",
  "exit_code": $rc,
  "ok": $ok,
  "incomplete": $incomplete,
  "summary": $summary
}
EOF
chmod 0644 "$tmp_status"
mv "$tmp_status" "$STATUS_DIR/$NAME.json"

# One run per line, appended. A separate file rather than a history array
# inside the status JSON, because appending a line needs no JSON parsing —
# and parsing JSON in POSIX sh, with no jq or python to lean on, is exactly
# how a status writer starts emitting malformed output.
history_file="$STATUS_DIR/$NAME.history.jsonl"
printf '{"finished":"%s","exit_code":%s,"ok":%s,"incomplete":%s,"summary":%s}\n' \
  "$finished" "$rc" "$ok" "$incomplete" "$summary" >>"$history_file"

# Bounded on every write. The console draws a two-week strip; keeping a little
# more than that leaves headroom without letting the file grow forever on a box
# nobody thinks to prune.
if tail -n "$HISTORY_KEEP" "$history_file" >"$history_file.tmp" 2>/dev/null; then
  mv "$history_file.tmp" "$history_file"
else
  rm -f "$history_file.tmp"
fi
chmod 0644 "$history_file"

exit "$rc"
